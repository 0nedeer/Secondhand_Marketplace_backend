<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.secondhand.marketplace.backend.modules.forum.mapper.ForumPostMediaMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.secondhand.marketplace.backend.modules.forum.entity.ForumPostMedia">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="post_id" property="postId" jdbcType="BIGINT"/>
        <result column="media_type" property="mediaType" jdbcType="VARCHAR"/>
        <result column="media_url" property="mediaUrl" jdbcType="VARCHAR"/>
        <result column="cover_url" property="coverUrl" jdbcType="VARCHAR"/>
        <result column="sort_no" property="sortNo" jdbcType="INTEGER"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>
    
    <!-- 基础字段列表 -->
    <sql id="Base_Column_List">
        id, post_id, media_type, media_url, cover_url, sort_no, created_at
    </sql>
    
    <!-- 插入 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO forum_post_media (post_id, media_type, media_url, cover_url, sort_no, created_at)
        VALUES (#{postId}, #{mediaType}, #{mediaUrl}, #{coverUrl}, #{sortNo}, #{createdAt})
    </insert>
    
    <!-- 根据ID删除 -->
    <delete id="deleteById">
        DELETE FROM forum_post_media WHERE id = #{id}
    </delete>
    
    <!-- 根据ID更新 -->
    <update id="updateById">
        UPDATE forum_post_media
        SET post_id = #{postId},
            media_type = #{mediaType},
            media_url = #{mediaUrl},
            cover_url = #{coverUrl},
            sort_no = #{sortNo},
            created_at = #{createdAt}
        WHERE id = #{id}
    </update>
    
    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM forum_post_media WHERE id = #{id}
    </select>
    
    <!-- 查询所有帖子媒体附件 -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM forum_post_media ORDER BY id DESC
    </select>
    
    <!-- 根据帖子ID查询媒体附件 -->
    <select id="selectByPostId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM forum_post_media WHERE post_id = #{postId} ORDER BY sort_no ASC, id ASC
    </select>
    
    <!-- 根据帖子ID删除所有媒体附件 -->
    <delete id="deleteByPostId">
        DELETE FROM forum_post_media WHERE post_id = #{postId}
    </delete>
    
</mapper>