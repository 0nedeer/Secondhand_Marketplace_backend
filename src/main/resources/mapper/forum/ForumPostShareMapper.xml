<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.secondhand.marketplace.backend.modules.forum.mapper.ForumPostShareMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.secondhand.marketplace.backend.modules.forum.entity.ForumPostShare">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="post_id" property="postId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="share_channel" property="shareChannel" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>
    
    <!-- 基础字段列表 -->
    <sql id="Base_Column_List">
        id, post_id, user_id, share_channel, created_at
    </sql>
    
    <!-- 插入 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO forum_post_share (post_id, user_id, share_channel, created_at)
        VALUES (#{postId}, #{userId}, #{shareChannel}, #{createdAt})
    </insert>
    
    <!-- 根据ID删除 -->
    <delete id="deleteById">
        DELETE FROM forum_post_share WHERE id = #{id}
    </delete>
    
    <!-- 根据ID更新 -->
    <update id="updateById">
        UPDATE forum_post_share
        SET post_id = #{postId},
            user_id = #{userId},
            share_channel = #{shareChannel},
            created_at = #{createdAt}
        WHERE id = #{id}
    </update>
    
    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM forum_post_share WHERE id = #{id}
    </select>
    
    <!-- 查询所有转发记录 -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM forum_post_share ORDER BY created_at DESC
    </select>
    
    <!-- 根据帖子ID查询转发记录 -->
    <select id="selectByPostId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM forum_post_share
        WHERE post_id = #{postId}
        ORDER BY created_at DESC
    </select>
    
    <!-- 根据用户ID查询转发记录 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM forum_post_share
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>
    
</mapper>